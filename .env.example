# =============================================================================
# OpenGradient — Verifiable AI Output Demo
# Copy this file to .env and fill in your values.
# =============================================================================

# REQUIRED — Base Sepolia wallet private key (must hold $OPG testnet tokens).
# Get tokens from https://faucet.opengradient.ai
OG_PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# OPTIONAL — Email for OpenGradient Model Hub authentication.
OG_EMAIL=

# OPTIONAL — Environment label shown in the UI (default: testnet).
OG_ENVIRONMENT=testnet
